[Unit]
Description=KTX/SRT cancellation ticket watch (telegram bot)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/ktx-watch
ExecStart=/usr/bin/python3 /home/ubuntu/ktx-watch/ktx_watch.py
Restart=always
RestartSec=30
Environment=PYTHONIOENCODING=utf-8

[Install]
WantedBy=multi-user.target
